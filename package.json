{
  "name": "@ohcj099/ai-pilot",
  "version": "1.0.0",
  "description": "统一管理多个 AI 编程助手 (Claude Code, Gemini CLI, Codex, DeepSeek, Reasonix) — 一键切换、并行对比、智能路由",
  "type": "module",
  "bin": {
    "ai-pilot": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js && node -e \"const f='dist/cli.js';require('fs').writeFileSync(f,'#!/usr/bin/env node\\n'+require('fs').readFileSync(f))\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "claude",
    "gemini",
    "codex",
    "deepseek",
    "reasonix",
    "cli",
    "coding-agent"
  ],
  "funding": {
    "type": "individual",
    "url": "https://ifdian.net/a/fengan666"
  },
  "author": "OHCJ099",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OHCJ099/ai-pilot.git"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "playwright": "^1.60.0"
  }
}
